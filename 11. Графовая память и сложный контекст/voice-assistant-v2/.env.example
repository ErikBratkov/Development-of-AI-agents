# Сервер
HOST=0.0.0.0
PORT=8000

# LLM через OpenRouter (OpenAI-совместимый API)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3.5-flash

# STT (локально, модель скачается сама при первом запуске)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=ru

# TTS (локально)
# TTS_VOICE - путь к .onnx файлу голоса piper, рядом должен лежать .onnx.json
# скачать голос: python -m piper.download_voices ru_RU-irina-medium
TTS_ENGINE=piper
TTS_VOICE=models/ru_RU-irina-medium.onnx

# Память и контекст
SYSTEM_PROMPT=Ты полезный голосовой ассистент. Отвечай кратко.
KEEP_LAST_TURNS=6
SUMMARIZE_TRIGGER_TOKENS=3000

# Neo4j (значения совпадают с docker-compose.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=graphdemo42
NEO4J_DATABASE=neo4j

# Гибридный поиск по базе знаний
# наполнение базы: docker compose up -d, потом python seed_knowledge.py
EMBEDDING_MODEL=intfloat/multilingual-e5-small
KB_TOP_K=4
KB_MAX_HOPS=2
KB_MAX_FACTS=30
